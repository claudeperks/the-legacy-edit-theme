<section class="sample-spreads section">
  <div class="page-width">

    <div class="sample-spreads__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="sample-spreads__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="sample-spreads__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="sample-spreads__sub">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="sample-spreads__grid">
      {% for block in section.blocks %}
        <div class="spread-card{% if block.settings.featured %} spread-card--featured{% endif %}" {{ block.shopify_attributes }}>
          <div class="spread-card__img-wrap">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'spread-card__img', alt: block.settings.caption }}
            {% else %}
              <div class="spread-card__placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                <span>{{ block.settings.caption | default: 'Add spread image' }}</span>
              </div>
            {% endif %}
          </div>
          {% if block.settings.tag != blank or block.settings.caption != blank %}
            <div class="spread-card__meta">
              {% if block.settings.tag != blank %}
                <span class="spread-card__tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.caption != blank %}
                <p class="spread-card__caption">{{ block.settings.caption }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Sample Spreads",
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "The work" },
    { "type": "text",     "id": "heading",    "label": "Heading",    "default": "See inside an Edit" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Every page is designed by hand. Here's what that looks like." }
  ],
  "blocks": [
    {
      "type": "spread",
      "name": "Spread",
      "settings": [
        { "type": "image_picker", "id": "image",    "label": "Image" },
        { "type": "text",         "id": "tag",      "label": "Tag (e.g. Wedding Edit)" },
        { "type": "text",         "id": "caption",  "label": "Caption" },
        { "type": "checkbox",     "id": "featured", "label": "Featured (wide)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sample Spreads",
      "blocks": [
        { "type": "spread", "settings": { "tag": "Wedding Edit",   "caption": "The ceremony, beautifully composed", "featured": true  } },
        { "type": "spread", "settings": { "tag": "Family Edit",    "caption": "Generations in one place",           "featured": false } },
        { "type": "spread", "settings": { "tag": "Travel Edit",    "caption": "Adventures that shaped you",         "featured": false } },
        { "type": "spread", "settings": { "tag": "Milestone Edit", "caption": "Achievements along the way",         "featured": false } }
      ]
    }
  ]
}
{% endschema %}
