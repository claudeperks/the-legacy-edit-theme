<header class="site-header">
  <div class="site-header__inner">

    <div class="site-header__logo">
      {% if section.settings.logo %}
        <a href="/">
          <img src="{{ section.settings.logo | img_url: '300x' }}" alt="{{ shop.name }}" height="28">
        </a>
      {% else %}
        <a href="/" class="site-header__logo-text">{{ shop.name }}</a>
      {% endif %}
    </div>

    <nav class="site-nav" id="site-nav" aria-label="Main navigation">
      {% for link in linklists[section.settings.menu].links %}
        <a href="{{ link.url }}" class="site-nav__link">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="site-header__right">
      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_link }}" class="btn btn--primary-dark site-header__cta">
          {{ section.settings.cta_label }}
        </a>
      {% endif %}
      <button class="site-header__icon-btn nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="site-nav">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo",      "label": "Logo" },
    { "type": "link_list",    "id": "menu",      "label": "Menu",          "default": "main-menu" },
    { "type": "text",         "id": "cta_label", "label": "CTA button",    "default": "Start Your Edit" },
    { "type": "url",          "id": "cta_link",  "label": "CTA link",      "default": "/collections/all" }
  ]
}
{% endschema %}
