<section class="mood-board">
  <div class="page-width">

    <!-- TOP: heading + body full width -->
    <div class="mood-board__top">
      {% if section.settings.eyebrow != blank %}
        <p class="mood-board__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="mood-board__heading">
        {{ section.settings.heading_before }}
        <em>{{ section.settings.heading_italic }}</em>
        {{ section.settings.heading_after }}
      </h2>
      {% if section.settings.body != blank %}
        <p class="mood-board__body">{{ section.settings.body }}</p>
      {% endif %}
    </div>

    <!-- BOTTOM: two boxes side by side -->
    <div class="mood-board__boxes">

      <!-- LEFT BOX: upload -->
      <div class="mood-board__box">
        <div class="mood-upload__zone" data-mood-zone>
          <input
            type="file"
            id="mood-upload-input"
            class="mood-upload__input"
            name="properties[Inspiration]"
            multiple
            accept="image/*,.pdf"
          >
          <label for="mood-upload-input" class="mood-upload__label-wrap">
            <span class="mood-upload__plus" aria-hidden="true">+</span>
            <span class="mood-upload__prompt">Drop your inspiration here</span>
            <span class="mood-upload__sub">Pinterest saves, screenshots, quotes, memes — anything that feels like you</span>
          </label>
        </div>
        <div class="mood-upload__previews" id="mood-previews"></div>
        <div class="mood-upload__tags">
          <span class="mood-tag">Pinterest</span>
          <span class="mood-tag">Screenshots</span>
          <span class="mood-tag">Quotes</span>
          <span class="mood-tag">Memes</span>
          <span class="mood-tag">Any file</span>
        </div>
      </div>

      <!-- RIGHT BOX: vibe + notes -->
      <div class="mood-board__box">
        <div class="mood-vibe">
          <p class="mood-vibe__label">Your vibe</p>
          <div class="mood-vibe__pills" data-vibe-group>
            {%- assign vibes = 'Romantic,Nostalgic,Funny,Bold,Minimal,Heartfelt,Chaotic,Soft,Timeless,Playful' | split: ',' -%}
            {% for vibe in vibes %}
              <button type="button" class="mood-pill{% if forloop.first %} is-active{% endif %}" data-vibe="{{ vibe }}">{{ vibe }}</button>
            {% endfor %}
          </div>
          <input type="hidden" name="properties[Vibe]" id="vibe-hidden" value="Romantic">
        </div>
        <div class="mood-notes">
          <p class="mood-notes__label">Tell us more</p>
          <textarea
            class="mood-notes__textarea"
            name="properties[Notes]"
            placeholder="Describe the feeling you want — our designers will take it from here..."
            rows="6"
          ></textarea>
        </div>
      </div>

    </div>

    <!-- BOTTOM: info + CTA -->
    <div class="mood-board__footer">
      <p class="mood-board__footer-text">{{ section.settings.footer_text }}</p>
      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="mood-board__cta">
          {{ section.settings.cta_label }} ↗
        </a>
      {% endif %}
    </div>

  </div>
</section>

<script>
(function() {
  function initMoodBoardSync() {
    // Restore saved vibe
    var savedVibe = localStorage.getItem('legacy_vibe');
    if (savedVibe) {
      document.querySelectorAll('[data-vibe-group] .mood-pill').forEach(function(p) {
        p.classList.toggle('is-active', p.dataset.vibe === savedVibe);
      });
      var vh = document.getElementById('vibe-hidden');
      if (vh) vh.value = savedVibe;
    }

    // Restore saved notes
    var savedNotes = localStorage.getItem('legacy_notes');
    var notesTA = document.querySelector('.mood-notes__textarea');
    if (notesTA && savedNotes) notesTA.value = savedNotes;

    // Save vibe on click
    document.querySelectorAll('[data-vibe-group] .mood-pill').forEach(function(pill) {
      pill.addEventListener('click', function() {
        localStorage.setItem('legacy_vibe', pill.dataset.vibe);
      });
    });

    // Save notes on input
    if (notesTA) {
      notesTA.addEventListener('input', function() {
        localStorage.setItem('legacy_notes', notesTA.value);
      });
    }

    // Save first uploaded image to sessionStorage for product page preview
    var moodInput = document.getElementById('mood-upload-input');
    if (moodInput) {
      moodInput.addEventListener('change', function(e) {
        var file = e.target.files[0];
        if (!file || !file.type.startsWith('image/')) return;
        var reader = new FileReader();
        reader.onload = function(ev) {
          var img = new Image();
          img.onload = function() {
            var canvas = document.createElement('canvas');
            var maxW = 900, maxH = 700;
            var ratio = Math.min(maxW / img.width, maxH / img.height, 1);
            canvas.width = Math.round(img.width * ratio);
            canvas.height = Math.round(img.height * ratio);
            canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
            try {
              sessionStorage.setItem('legacy_upload_preview', canvas.toDataURL('image/jpeg', 0.75));
            } catch(e) { /* storage full */ }
          };
          img.src = ev.target.result;
        };
        reader.readAsDataURL(file);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMoodBoardSync);
  } else {
    initMoodBoardSync();
  }
})();
</script>

{% schema %}
{
  "name": "Mood Board",
  "settings": [
    { "type": "text",     "id": "eyebrow",         "label": "Eyebrow",                 "default": "The mood board" },
    { "type": "text",     "id": "heading_before",  "label": "Heading — before italic", "default": "Make it" },
    { "type": "text",     "id": "heading_italic",  "label": "Heading — italic word",   "default": "unmistakably" },
    { "type": "text",     "id": "heading_after",   "label": "Heading — after italic",  "default": "yours" },
    { "type": "textarea", "id": "body",            "label": "Body text",               "default": "Screenshot your favourite Pinterest quotes. Save the memes that made you cry-laugh. Grab the words that just get you. Upload them — and we'll weave them into your Edit. Beautifully designed, perfectly placed." },
    { "type": "text",     "id": "footer_text",    "label": "Footer info text",        "default": "Files up to 50MB · Any format · Our designers handle the rest." },
    { "type": "text",     "id": "cta_label",      "label": "CTA button label",        "default": "Add to my Edit" },
    { "type": "url",      "id": "cta_link",       "label": "CTA button link",         "default": "/collections/all" }
  ],
  "presets": [{ "name": "Mood Board" }]
}
{% endschema %}
