<section class="hero-split">
  <div class="hero-split__left">
    {% if section.settings.eyebrow != blank %}
      <p class="hero-split__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    <h1 class="hero-split__heading">{{ section.settings.heading | newline_to_br }}</h1>

    {% if section.settings.subheading != blank %}
      <p class="hero-split__sub">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="hero-split__buttons">
      {% if section.settings.btn1_label != blank %}
        <a href="{{ section.settings.btn1_link }}" class="btn btn--primary-dark">{{ section.settings.btn1_label }}</a>
      {% endif %}
      {% if section.settings.btn2_label != blank %}
        <a href="{{ section.settings.btn2_link }}" class="btn btn--secondary">{{ section.settings.btn2_label }}</a>
      {% endif %}
    </div>
  </div>

  <div class="hero-split__right">
    {% if section.settings.image %}
      <img
        src="{{ section.settings.image | img_url: '1200x' }}"
        alt="{{ section.settings.heading | escape }}"
        loading="eager"
        class="hero-split__img"
      >
    {% else %}
      <div class="hero-split__placeholder">
        {{ 'image' | placeholder_svg_tag: 'hero-split__placeholder-svg' }}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text",     "id": "eyebrow",     "label": "Eyebrow",      "default": "Handcrafted heirlooms" },
    { "type": "textarea", "id": "heading",     "label": "Heading",      "default": "Your story.\nYour aesthetic.\nBeautifully kept." },
    { "type": "textarea", "id": "subheading",  "label": "Description",  "default": "More than a photo book. A designed heirloom built around you — your photos, your Pinterest saves, your quotes, your vibe." },
    { "type": "text",     "id": "btn1_label",  "label": "Button 1 label", "default": "Start your Edit" },
    { "type": "url",      "id": "btn1_link",   "label": "Button 1 link",  "default": "/collections/all" },
    { "type": "text",     "id": "btn2_label",  "label": "Button 2 label", "default": "See the collection" },
    { "type": "url",      "id": "btn2_link",   "label": "Button 2 link",  "default": "/collections/all" },
    { "type": "image_picker", "id": "image",   "label": "Right-side image" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
