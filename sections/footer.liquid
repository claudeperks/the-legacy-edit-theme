<footer class="site-footer">
  <div class="page-width">
    <div class="site-footer__grid">
      <div>
        <p class="site-footer__brand-name">{{ shop.name }}</p>
        <p class="site-footer__brand-desc">{{ section.settings.brand_desc }}</p>
        <div class="site-footer__social">
          {% if section.settings.instagram != blank %}
            <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener">Instagram</a>
          {% endif %}
          {% if section.settings.tiktok != blank %}
            <a href="{{ section.settings.tiktok }}" target="_blank" rel="noopener">TikTok</a>
          {% endif %}
        </div>
      </div>
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div {{ block.shopify_attributes }}>
            <p class="site-footer__col-title">{{ block.settings.title }}</p>
            <ul class="site-footer__links">
              {% if block.settings.link_1_label != blank %}<li><a href="{{ block.settings.link_1_url }}">{{ block.settings.link_1_label }}</a></li>{% endif %}
              {% if block.settings.link_2_label != blank %}<li><a href="{{ block.settings.link_2_url }}">{{ block.settings.link_2_label }}</a></li>{% endif %}
              {% if block.settings.link_3_label != blank %}<li><a href="{{ block.settings.link_3_url }}">{{ block.settings.link_3_label }}</a></li>{% endif %}
              {% if block.settings.link_4_label != blank %}<li><a href="{{ block.settings.link_4_url }}">{{ block.settings.link_4_label }}</a></li>{% endif %}
            </ul>
          </div>
        {% endfor %}
      {% else %}
        <div>
          <p class="site-footer__col-title">Shop</p>
          <ul class="site-footer__links">
            <li><a href="/products/the-legacy-edit-custom-photo-book">The Collection</a></li>
            <li><a href="/products/the-legacy-edit-custom-photo-book">Start your Edit</a></li>
            <li><a href="/products/the-legacy-edit-custom-photo-book">Pricing</a></li>
          </ul>
        </div>
        <div>
          <p class="site-footer__col-title">The Edits</p>
          <ul class="site-footer__links">
            <li><a href="/products/the-legacy-edit-custom-photo-book#edit=The%20Wedding%20Edit">The Wedding Edit</a></li>
            <li><a href="/products/the-legacy-edit-custom-photo-book#edit=The%20Family%20Edit">The Family Edit</a></li>
            <li><a href="/products/the-legacy-edit-custom-photo-book#edit=The%20Travel%20Edit">The Travel Edit</a></li>
            <li><a href="/products/the-legacy-edit-custom-photo-book#edit=The%20Everyday%20Edit">The Everyday Edit</a></li>
          </ul>
        </div>
        <div>
          <p class="site-footer__col-title">Help</p>
          <ul class="site-footer__links">
            <li><a href="/policies/shipping-policy">Shipping</a></li>
            <li><a href="/policies/refund-policy">Returns</a></li>
            <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          </ul>
        </div>
      {% endif %}
    </div>
    <div class="site-footer__bottom">
      <p class="site-footer__copyright">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <nav class="site-footer__legal">
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms</a>
        <a href="/policies/shipping-policy">Shipping</a>
        <a href="/policies/refund-policy">Returns</a>
      </nav>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "brand_desc", "label": "Brand description", "default": "Handcrafted books for the modern collector." },
    { "type": "text", "id": "instagram", "label": "Instagram URL" },
    { "type": "text", "id": "tiktok", "label": "TikTok URL" }
  ],
  "blocks": [
    {
      "type": "link-column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "title", "label": "Column title" },
        { "type": "text", "id": "link_1_label", "label": "Link 1 label" },
        { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 label" },
        { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 label" },
        { "type": "url", "id": "link_3_url", "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 label" },
        { "type": "url", "id": "link_4_url", "label": "Link 4 URL" }
      ]
    }
  ],
  "presets": [{
    "name": "Footer",
    "blocks": [
      { "type": "link-column", "settings": { "title": "Shop", "link_1_label": "All Books", "link_1_url": "/collections/all" }},
      { "type": "link-column", "settings": { "title": "Company", "link_1_label": "Our Story", "link_1_url": "/pages/our-story", "link_2_label": "Contact", "link_2_url": "/pages/contact" }},
      { "type": "link-column", "settings": { "title": "Support", "link_1_label": "Shipping", "link_1_url": "/policies/shipping-policy", "link_2_label": "Returns", "link_2_url": "/policies/refund-policy" }}
    ]
  }]
}
{% endschema %}
