<div class="marquee-section">
  <div class="marquee-track">
    {% for i in (1..2) %}
      {% for block in section.blocks %}
        <span class="marquee-track__item">{{ block.settings.text }}</span>
        <span class="marquee-track__separator">·</span>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Handcrafted with care" }
      ]
    }
  ],
  "presets": [{
    "name": "Marquee",
    "blocks": [
      { "type": "item", "settings": { "text": "Handcrafted with care" }},
      { "type": "item", "settings": { "text": "Free shipping available" }},
      { "type": "item", "settings": { "text": "Limited editions" }},
      { "type": "item", "settings": { "text": "Collector's quality" }}
    ]
  }]
}
{% endschema %}
