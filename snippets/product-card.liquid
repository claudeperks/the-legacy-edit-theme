<div class="product-card">
  <a href="{{ product.url }}" class="product-card__media">
    {% if product.featured_image %}
      <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title }}" loading="lazy">
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}
    {% if product.compare_at_price > product.price %}
      <span class="product-card__badge">Sale</span>
    {% endif %}
  </a>
  <div class="product-card__info">
    <p class="product-card__title">{{ product.title }}</p>
    <p class="product-card__price">
      {% if product.compare_at_price > product.price %}
        <s>{{ product.compare_at_price | money }}</s>
      {% endif %}
      {{ product.price | money }}
    </p>
    <button class="product-card__add" data-variant-id="{{ product.first_available_variant.id }}">Add</button>
  </div>
</div>
