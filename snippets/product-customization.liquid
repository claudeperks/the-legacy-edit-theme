<div class="product-customization">
  <p class="product-customization__heading">Personalise your Edit</p>

  <!-- Title -->
  <div class="custom-field">
    <label class="custom-field__label" for="custom-title">Title</label>
    <input
      type="text"
      id="custom-title"
      name="properties[Title]"
      class="custom-field__input"
      placeholder="e.g. The Johnson Family"
    >
  </div>

  <!-- Subtitle -->
  <div class="custom-field">
    <label class="custom-field__label" for="custom-subtitle">Subtitle</label>
    <input
      type="text"
      id="custom-subtitle"
      name="properties[Subtitle]"
      class="custom-field__input"
      placeholder="e.g. 2024"
    >
  </div>

  <!-- Footer Title -->
  <div class="custom-field">
    <label class="custom-field__label" for="custom-footer">Footer Title</label>
    <input
      type="text"
      id="custom-footer"
      name="properties[Footer Title]"
      class="custom-field__input"
      placeholder="e.g. A Legacy Edit"
    >
  </div>

  <!-- Memo Page -->
  <div class="custom-field">
    <label class="custom-field__label" for="custom-memo">
      Memo Page
      <span class="custom-field__hint">A personal note printed inside your Edit</span>
    </label>
    <textarea
      id="custom-memo"
      name="properties[Memo Page]"
      class="custom-field__textarea"
      placeholder="Type here..."
      rows="4"
    ></textarea>
  </div>

  <!-- Linen Color -->
  <div class="custom-field">
    <label class="custom-field__label">Linen Color</label>
    <div class="linen-swatches">

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Cream">
        <span class="swatch" style="background:#F2EDE4;" title="Cream"></span>
        <span class="swatch-label">Cream</span>
      </label>

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Beige">
        <span class="swatch" style="background:#C8B89A;" title="Beige"></span>
        <span class="swatch-label">Beige</span>
      </label>

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Brown">
        <span class="swatch" style="background:#6B4C3B;" title="Brown"></span>
        <span class="swatch-label">Brown</span>
      </label>

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Black">
        <span class="swatch" style="background:#1A1A1A;" title="Black"></span>
        <span class="swatch-label">Black</span>
      </label>

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Blue">
        <span class="swatch" style="background:#2C4A6E;" title="Blue"></span>
        <span class="swatch-label">Blue</span>
      </label>

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Gray">
        <span class="swatch" style="background:#8C8C8C;" title="Gray"></span>
        <span class="swatch-label">Gray</span>
      </label>

    </div>
  </div>

</div>
