<div class="product-customization">
  <p class="product-customization__heading">Personalise your Edit</p>

  <!-- Title -->
  <div class="custom-field">
    <label class="custom-field__label" for="custom-title">Title</label>
    <input
      type="text"
      id="custom-title"
      name="properties[Title]"
      class="custom-field__input"
      placeholder="e.g. The Johnson Family"
    >
  </div>

  <!-- Subtitle -->
  <div class="custom-field">
    <label class="custom-field__label" for="custom-subtitle">Subtitle</label>
    <input
      type="text"
      id="custom-subtitle"
      name="properties[Subtitle]"
      class="custom-field__input"
      placeholder="e.g. 2024"
    >
  </div>

  <!-- Footer Title -->
  <div class="custom-field">
    <label class="custom-field__label" for="custom-footer">Footer Title</label>
    <input
      type="text"
      id="custom-footer"
      name="properties[Footer Title]"
      class="custom-field__input"
      placeholder="e.g. A Legacy Edit"
    >
  </div>

  <!-- Memo Page -->
  <div class="custom-field">
    <label class="custom-field__label" for="custom-memo">
      Memo Page
      <span class="custom-field__hint">A personal note printed inside your Edit</span>
    </label>
    <textarea
      id="custom-memo"
      name="properties[Memo Page]"
      class="custom-field__textarea"
      placeholder="Type here..."
      rows="4"
    ></textarea>
  </div>

  <!-- Your Vibe (auto-filled from mood board) -->
  <div class="custom-field" id="vibe-field" style="display:none;">
    <label class="custom-field__label">
      Your Vibe
      <span class="custom-field__hint">Saved from your mood board</span>
    </label>
    <div class="vibe-autofill">
      <span class="vibe-autofill__pill" id="vibe-autofill-display"></span>
      <button type="button" class="vibe-autofill__clear" id="vibe-autofill-clear">✕ Clear</button>
    </div>
    <input type="hidden" name="properties[Vibe]" id="custom-vibe-value">
  </div>

  <!-- Linen Color -->
  <div class="custom-field">
    <label class="custom-field__label">Linen Color</label>
    <div class="linen-swatches">

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Cream">
        <span class="swatch" style="background:#F2EDE4;" title="Cream"></span>
        <span class="swatch-label">Cream</span>
      </label>

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Beige">
        <span class="swatch" style="background:#C8B89A;" title="Beige"></span>
        <span class="swatch-label">Beige</span>
      </label>

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Brown">
        <span class="swatch" style="background:#6B4C3B;" title="Brown"></span>
        <span class="swatch-label">Brown</span>
      </label>

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Black">
        <span class="swatch" style="background:#1A1A1A;" title="Black"></span>
        <span class="swatch-label">Black</span>
      </label>

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Blue">
        <span class="swatch" style="background:#2C4A6E;" title="Blue"></span>
        <span class="swatch-label">Blue</span>
      </label>

      <label class="swatch-option">
        <input type="radio" name="properties[Linen Color]" value="Gray">
        <span class="swatch" style="background:#8C8C8C;" title="Gray"></span>
        <span class="swatch-label">Gray</span>
      </label>

    </div>
  </div>

</div>

<script>
(function() {
  var editMap = {
    wedding:   { title: 'The Wedding Edit',   subtitle: 'The big day, beautifully told' },
    family:    { title: 'The Family Edit',    subtitle: 'The people who ground you' },
    party:     { title: 'The Party Edit',     subtitle: 'Celebrations worth remembering' },
    travel:    { title: 'The Travel Edit',    subtitle: 'Adventures that shaped you' },
    milestone: { title: 'The Milestone Edit', subtitle: 'Achievements along the way' },
    everyday:  { title: 'The Everyday Edit',  subtitle: 'The quiet moments that matter' }
  };

  function autoFill() {
    // 1. Fill from URL ?edit= param OR sessionStorage (whichever has a value)
    var editKey = new URLSearchParams(window.location.search).get('edit')
                  || sessionStorage.getItem('legacy_edit_key');
    sessionStorage.removeItem('legacy_edit_key'); // clear after reading
    if (editKey && editMap[editKey]) {
      var titleInput    = document.getElementById('custom-title');
      var subtitleInput = document.getElementById('custom-subtitle');
      if (titleInput    && !titleInput.value)    titleInput.value    = editMap[editKey].title;
      if (subtitleInput && !subtitleInput.value) subtitleInput.value = editMap[editKey].subtitle;
    }

    // 2. Fill memo + vibe from mood board (localStorage)
    var savedNotes = localStorage.getItem('legacy_notes');
    if (savedNotes) {
      var memo = document.getElementById('custom-memo');
      if (memo && !memo.value) memo.value = savedNotes;
    }

    var savedVibe = localStorage.getItem('legacy_vibe');
    if (savedVibe) {
      var field   = document.getElementById('vibe-field');
      var display = document.getElementById('vibe-autofill-display');
      var hidden  = document.getElementById('custom-vibe-value');
      if (field)   field.style.display = '';
      if (display) display.textContent = savedVibe;
      if (hidden)  hidden.value = savedVibe;
    }

    var clearBtn = document.getElementById('vibe-autofill-clear');
    if (clearBtn) {
      clearBtn.addEventListener('click', function() {
        localStorage.removeItem('legacy_vibe');
        var f = document.getElementById('vibe-field');
        if (f) f.style.display = 'none';
        var h = document.getElementById('custom-vibe-value');
        if (h) h.value = '';
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', autoFill);
  } else {
    autoFill();
  }
})();
</script>
