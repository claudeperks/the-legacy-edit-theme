{% layout 'theme' %}

<!-- Breadcrumb -->
<div class="product-breadcrumb page-width">
  <a href="/">Home</a>
  <span>/</span>
  <a href="/products/the-legacy-edit-custom-photo-book">Photo Books</a>
  <span>/</span>
  <span>{{ product.title }}</span>
</div>

<!-- ═══ PRODUCT HERO ═══ -->
<div class="product-hero page-width">

  <!-- LEFT: Gallery -->
  <div class="product-gallery">
    <div class="product-gallery__main">
      {% if product.featured_image %}
        <img
          id="gallery-main-img"
          src="{{ product.featured_image | image_url: width: 1200 }}"
          alt="{{ product.title }}"
          loading="eager"
          class="product-gallery__main-img"
        >
      {% else %}
        <img
          id="gallery-main-img"
          src="https://picsum.photos/seed/legacybook/1200/900"
          alt="{{ product.title }}"
          loading="eager"
          class="product-gallery__main-img"
        >
      {% endif %}
    </div>

    {% if product.images.size > 1 %}
      <div class="product-gallery__thumbs">
        {% for image in product.images %}
          <button
            type="button"
            class="gallery-thumb{% if forloop.first %} is-active{% endif %}"
            data-src="{{ image | image_url: width: 1200 }}"
            aria-label="View image {{ forloop.index }}"
          >
            <img
              src="{{ image | image_url: width: 180 }}"
              alt="{{ product.title }} view {{ forloop.index }}"
              loading="lazy"
            >
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- RIGHT: Product Info -->
  <div class="product-info">

    <p class="product-info__eyebrow">{{ product.vendor | default: 'The Legacy Edit' }}</p>
    <h1 class="product-info__title">{{ product.title }}</h1>

    <div class="product-info__pricing-row">
      <p class="product-info__price" id="product-price">
        {% if product.price_varies %}From {{ product.price_min | money }}{% else %}{{ product.price | money }}{% endif %}
      </p>
      {% if product.compare_at_price > product.price %}
        <s class="product-info__compare-price">{{ product.compare_at_price | money }}</s>
        <span class="product-info__badge">Sale</span>
      {% endif %}
    </div>

    {% if product.description != blank %}
      <p class="product-info__tagline">{{ product.description | strip_html | truncatewords: 25 }}</p>
    {% endif %}

    {% form 'product', product, id: 'product-form' %}
      <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">

      {% unless product.has_only_default_variant %}
        <div class="product-options">
          {% for option in product.options_with_values %}
            <div class="product-option">
              <span class="product-option__label">{{ option.name }}</span>
              <div class="product-option__values" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  <button
                    type="button"
                    class="option-btn{% if option.selected_value == value %} is-active{% endif %}"
                    data-value="{{ value }}"
                    data-option="{{ forloop.parentloop.index0 }}"
                  >{{ value }}</button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endunless %}

      <!-- Personalisation Options -->
      {% render 'product-customization' %}

      <!-- Upload Zones -->
      <div class="product-info__uploads">
        {% render 'upload-zones' %}
      </div>

      <button
        type="submit"
        class="btn btn--primary-dark btn--full product-info__submit"
        {% unless product.available %}disabled{% endunless %}
      >
        {% if product.available %}Start your Edit ↗{% else %}Sold Out{% endif %}
      </button>

      <p class="product-info__guarantee">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Always backed by our quality guarantee
      </p>

    {% endform %}

    <!-- Product Features Accordion (in right col) -->
    <div class="product-accordion">

      <details class="product-accordion__item" open>
        <summary class="product-accordion__summary">Product Features</summary>
        <div class="product-accordion__body">
          <p class="product-accordion__lead">A little book with big impact</p>
          <ul>
            <li>13 × 9 inches — one deliberate, coffee-table size</li>
            <li>Premium linen hardcover, foil-stamped spine</li>
            <li>Up to 80 fully custom-designed pages</li>
            <li>Archival matte paper — thick, flat-lying spreads</li>
            <li>Mood board integration — your pins, quotes &amp; vibe woven in</li>
            <li>Digital proof for approval before printing</li>
            <li>No templates. Every layout built from scratch.</li>
          </ul>
        </div>
      </details>

      <details class="product-accordion__item">
        <summary class="product-accordion__summary">Shipping &amp; Returns</summary>
        <div class="product-accordion__body">
          <table class="product-shipping-table">
            <thead><tr><th>Service</th><th>Timeframe</th></tr></thead>
            <tbody>
              <tr><td>Standard</td><td>5–7 days after proof approval</td></tr>
              <tr><td>Expedited</td><td>3–4 business days</td></tr>
              <tr><td>Rush</td><td>1–2 business days</td></tr>
            </tbody>
          </table>
          <p style="margin-top:0.875rem;">Every Edit is made to order. If there's a print quality issue we'll reprint at no cost — guaranteed.</p>
        </div>
      </details>

      <details class="product-accordion__item">
        <summary class="product-accordion__summary">How It Works</summary>
        <div class="product-accordion__body">
          <p>Upload your photos and mood board below. Our designers build your Edit entirely from scratch — no templates, no shortcuts. You'll receive a digital proof to approve before we print and ship.</p>
        </div>
      </details>

    </div>

    <!-- Trust Badges -->
    <div class="product-trust-badges">
      <div class="product-trust-badge">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Free UK Shipping
      </div>
      <div class="product-trust-badge">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
        Proof Before Print
      </div>
      <div class="product-trust-badge">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Linen Hardcover Only
      </div>
    </div>

  </div>
</div>

<!-- ═══ RELATED PRODUCTS ═══ -->
{% assign related = collections['all'].products | where: 'id', product.id %}
<div class="related-products">
  <div class="page-width">
    <h2 class="related-products__heading">You May Also Like</h2>
    <div class="related-products__grid">
      {% for p in collections.all.products limit: 5 %}
        {% unless p.id == product.id %}
          <a href="{{ p.url }}" class="related-card">
            <div class="related-card__img-wrap">
              {% if p.featured_image %}
                <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title }}" loading="lazy">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
            </div>
            <p class="related-card__title">{{ p.title }}</p>
            <p class="related-card__price">From {{ p.price | money }}</p>
          </a>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</div>

<!-- ═══ TRUST ICONS ═══ -->
<div class="product-trust-section">
  <div class="page-width">
    <p class="product-trust-section__heading">Because Your Story Matters</p>
    <div class="product-trust-row">
      <div class="trust-item">
        <div class="trust-item__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>
        <p class="trust-item__title">Premium Quality Products</p>
        <p class="trust-item__body">Carefully crafted with love-tested materials that let your most meaningful stories live on.</p>
      </div>
      <div class="trust-item">
        <div class="trust-item__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <p class="trust-item__title">Thoughtfully Sourced Materials</p>
        <p class="trust-item__body">Because the moments that are worth preserving happen in places that are worth protecting.</p>
      </div>
      <div class="trust-item">
        <div class="trust-item__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </div>
        <p class="trust-item__title">Made to Love, Guaranteed</p>
        <p class="trust-item__body">If you're not completely happy with your order experience, we'll make it craft — human to human.</p>
      </div>
      <div class="trust-item">
        <div class="trust-item__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <p class="trust-item__title">Handmade in the UK</p>
        <p class="trust-item__body">We maintain a deep connection with the artisans we create by crafting them close to home.</p>
      </div>
    </div>
  </div>
</div>

<script>
  // Show mood board uploaded image in gallery if available
  (function() {
    var preview = sessionStorage.getItem('legacy_upload_preview');
    if (!preview) return;
    var mainImg = document.getElementById('gallery-main-img');
    if (!mainImg) return;

    // Add uploaded image as first thumbnail and set as main
    var thumbsWrap = document.querySelector('.product-gallery__thumbs');

    // Create thumbnail for the uploaded image
    var uploadThumb = document.createElement('button');
    uploadThumb.type = 'button';
    uploadThumb.className = 'gallery-thumb is-active';
    uploadThumb.dataset.src = preview;
    uploadThumb.innerHTML = '<img src="' + preview + '" alt="Your uploaded photo">';
    uploadThumb.setAttribute('aria-label', 'Your uploaded photo');

    // Deactivate existing first thumb
    if (thumbsWrap) {
      var existing = thumbsWrap.querySelector('.gallery-thumb.is-active');
      if (existing) existing.classList.remove('is-active');
      thumbsWrap.insertBefore(uploadThumb, thumbsWrap.firstChild);
    }

    // Set as main image
    mainImg.src = preview;

    // Add label above gallery
    var gallery = document.querySelector('.product-gallery');
    if (gallery) {
      var badge = document.createElement('p');
      badge.className = 'gallery-upload-badge';
      badge.textContent = 'Your uploaded photo';
      gallery.insertBefore(badge, gallery.firstChild);
    }
  })();

  // Auto-fill personalisation fields from edit card click
  (function() {
    var editMap = {
      wedding:   { title: 'The Wedding Edit',   subtitle: 'The big day, beautifully told' },
      family:    { title: 'The Family Edit',    subtitle: 'The people who ground you' },
      party:     { title: 'The Party Edit',     subtitle: 'Celebrations worth remembering' },
      travel:    { title: 'The Travel Edit',    subtitle: 'Adventures that shaped you' },
      milestone: { title: 'The Milestone Edit', subtitle: 'Achievements along the way' },
      everyday:  { title: 'The Everyday Edit',  subtitle: 'The quiet moments that matter' }
    };
    var editKey = new URLSearchParams(window.location.search).get('edit')
                  || sessionStorage.getItem('legacy_edit_key');
    sessionStorage.removeItem('legacy_edit_key');
    if (editKey && editMap[editKey]) {
      var t = document.getElementById('custom-title');
      var s = document.getElementById('custom-subtitle');
      if (t && !t.value) t.value = editMap[editKey].title;
      if (s && !s.value) s.value = editMap[editKey].subtitle;
    }
  })();

  // Gallery thumbnails
  document.querySelectorAll('.gallery-thumb').forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var img = document.getElementById('gallery-main-img');
      if (img) { img.style.opacity = '0.6'; img.src = thumb.dataset.src; setTimeout(function(){ img.style.opacity = '1'; }, 150); }
      document.querySelectorAll('.gallery-thumb').forEach(function(t) { t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
    });
  });

  // Variant selection
  var productVariants = {{ product.variants | json }};
  var selectedOptions = {};
  var defaultVariant = {{ product.selected_or_first_available_variant | json }};
  if (defaultVariant && defaultVariant.options) {
    defaultVariant.options.forEach(function(val, idx) { selectedOptions[idx] = val; });
  }

  document.querySelectorAll('.option-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      selectedOptions[parseInt(btn.dataset.option)] = btn.dataset.value;
      btn.closest('.product-option__values').querySelectorAll('.option-btn').forEach(function(b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      var variant = productVariants.find(function(v) {
        return Object.keys(selectedOptions).every(function(idx) { return v.options[idx] === selectedOptions[idx]; });
      });
      if (variant) {
        document.getElementById('variant-id').value = variant.id;
        var el = document.getElementById('product-price');
        if (el) el.textContent = new Intl.NumberFormat('en-GB', { style: 'currency', currency: 'GBP' }).format(variant.price / 100);
      }
    });
  });
</script>
