{% layout 'theme' %}

<!-- ═══ PRODUCT HERO ═══ -->
<div class="product-hero">

  <!-- LEFT: Sticky Gallery -->
  <div class="product-gallery">
    <div class="product-gallery__main">
      {% if product.featured_image %}
        <img
          id="gallery-main-img"
          src="{{ product.featured_image | image_url: width: 1400 }}"
          alt="{{ product.title }}"
          loading="eager"
          class="product-gallery__main-img"
        >
      {% else %}
        <div class="product-gallery__placeholder">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    {% if product.images.size > 1 %}
      <div class="product-gallery__thumbs">
        {% for image in product.images %}
          <button
            type="button"
            class="gallery-thumb{% if forloop.first %} is-active{% endif %}"
            data-src="{{ image | image_url: width: 1400 }}"
            aria-label="View image {{ forloop.index }}"
          >
            <img
              src="{{ image | image_url: width: 200 }}"
              alt="{{ product.title }} — view {{ forloop.index }}"
              loading="lazy"
            >
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- RIGHT: Product Info -->
  <div class="product-info">

    <p class="product-info__eyebrow">{{ product.vendor | default: 'The Legacy Edit' }}</p>
    <h1 class="product-info__title">{{ product.title }}</h1>

    <p class="product-info__price" id="product-price">
      {% if product.price_varies %}
        From {{ product.price_min | money }}
      {% else %}
        {{ product.price | money }}
      {% endif %}
    </p>

    {% if product.description != blank %}
      <p class="product-info__tagline">{{ product.description | strip_html | truncatewords: 35 }}</p>
    {% endif %}

    {% form 'product', product, id: 'product-form' %}
      <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">

      <!-- Variant Options -->
      {% unless product.has_only_default_variant %}
        <div class="product-options">
          {% for option in product.options_with_values %}
            <div class="product-option">
              <span class="product-option__label">{{ option.name }}</span>
              <div class="product-option__values" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  <button
                    type="button"
                    class="option-btn{% if option.selected_value == value %} is-active{% endif %}"
                    data-value="{{ value }}"
                    data-option="{{ forloop.parentloop.index0 }}"
                  >{{ value }}</button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endunless %}

      <!-- Upload Zones -->
      <div class="product-info__uploads">
        {% render 'upload-zones' %}
      </div>

      <button
        type="submit"
        class="btn btn--primary-dark btn--full product-info__submit"
        {% unless product.available %}disabled{% endunless %}
      >
        {% if product.available %}Start your Edit ↗{% else %}Sold Out{% endif %}
      </button>

    {% endform %}

    <!-- Trust Badges -->
    <div class="product-trust-badges">
      <div class="product-trust-badge">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Free Shipping
      </div>
      <div class="product-trust-badge">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Linen Hardcover
      </div>
      <div class="product-trust-badge">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
        100% Custom Pages
      </div>
      <div class="product-trust-badge">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Proof Before Print
      </div>
    </div>

  </div>
</div>

<!-- ═══ BELOW FOLD ═══ -->
<div class="product-below page-width">

  <!-- Accordion -->
  <div class="product-accordion">

    <details class="product-accordion__item">
      <summary class="product-accordion__summary">What's Included</summary>
      <div class="product-accordion__body">
        <ul>
          <li>Linen hardcover — 13 × 9 inches, one deliberate size</li>
          <li>Up to 80 fully custom-designed pages</li>
          <li>Mood board integration — your pins, quotes &amp; vibe woven in</li>
          <li>Digital proof for approval before we print</li>
          <li>Premium archival matte paper throughout</li>
          <li>Foil-stamped spine detail</li>
        </ul>
      </div>
    </details>

    <details class="product-accordion__item">
      <summary class="product-accordion__summary">How It Works</summary>
      <div class="product-accordion__body">
        <p>After placing your order you'll receive a secure upload link via email. Share your photos, Pinterest screenshots, quotes, and any other inspiration. Our designers build your Edit entirely from scratch — no templates, ever. You'll receive a digital proof for approval before we send it to print. Expect your heirloom in 5–7 business days from proof approval.</p>
      </div>
    </details>

    <details class="product-accordion__item">
      <summary class="product-accordion__summary">Shipping &amp; Returns</summary>
      <div class="product-accordion__body">
        <table class="product-shipping-table">
          <thead><tr><th>Service</th><th>Timeframe</th></tr></thead>
          <tbody>
            <tr><td>Standard</td><td>5–7 days after proof approval</td></tr>
            <tr><td>Expedited</td><td>3–4 business days</td></tr>
            <tr><td>Rush</td><td>1–2 business days</td></tr>
          </tbody>
        </table>
        <p style="margin-top:1rem;">Every Edit is made to order. Due to the custom nature of our work we cannot accept returns. If there is a print quality issue we will reprint at no cost — guaranteed.</p>
      </div>
    </details>

    <details class="product-accordion__item">
      <summary class="product-accordion__summary">Full Description</summary>
      <div class="product-accordion__body">
        {{ product.description }}
      </div>
    </details>

  </div>

  <!-- Trust Icons -->
  <div class="product-trust-row">
    <div class="trust-item">
      <div class="trust-item__icon">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      </div>
      <p class="trust-item__title">Premium Quality</p>
      <p class="trust-item__body">Archival paper. Linen cover. Built to outlast generations.</p>
    </div>
    <div class="trust-item">
      <div class="trust-item__icon">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <p class="trust-item__title">Handmade in the UK</p>
      <p class="trust-item__body">Designed and printed by our team. Never outsourced.</p>
    </div>
    <div class="trust-item">
      <div class="trust-item__icon">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
      </div>
      <p class="trust-item__title">Proof Guarantee</p>
      <p class="trust-item__body">See your Edit before it prints. Approve with full confidence.</p>
    </div>
    <div class="trust-item">
      <div class="trust-item__icon">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      </div>
      <p class="trust-item__title">Free UK Shipping</p>
      <p class="trust-item__body">On all orders. International shipping available at checkout.</p>
    </div>
  </div>

</div>

<script>
  // Gallery thumbnails
  document.querySelectorAll('.gallery-thumb').forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var img = document.getElementById('gallery-main-img');
      if (img) img.src = thumb.dataset.src;
      document.querySelectorAll('.gallery-thumb').forEach(function(t) { t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
    });
  });

  // Variant option selection
  var productVariants = {{ product.variants | json }};
  var selectedOptions = {};

  // Seed selected options from default variant
  var defaultVariant = {{ product.selected_or_first_available_variant | json }};
  if (defaultVariant && defaultVariant.options) {
    defaultVariant.options.forEach(function(val, idx) { selectedOptions[idx] = val; });
  }

  document.querySelectorAll('.option-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var optionIndex = parseInt(btn.dataset.option);
      selectedOptions[optionIndex] = btn.dataset.value;

      btn.closest('.product-option__values').querySelectorAll('.option-btn').forEach(function(b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');

      var variant = productVariants.find(function(v) {
        return Object.keys(selectedOptions).every(function(idx) {
          return v.options[idx] === selectedOptions[idx];
        });
      });

      if (variant) {
        document.getElementById('variant-id').value = variant.id;
        var priceEl = document.getElementById('product-price');
        if (priceEl) {
          var formatted = new Intl.NumberFormat('en-GB', { style: 'currency', currency: 'GBP' }).format(variant.price / 100);
          priceEl.textContent = formatted;
        }
      }
    });
  });
</script>
